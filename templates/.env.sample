# .claude/.env — Credentials for AI skills (Copilot, Claude, etc.)
# This file is NOT part of the project runtime configuration.
# Copy to .claude/.env and fill in your values.
# This file is gitignored — never commit real credentials.

# Jira Configuration 
JIRA_DOMAIN=your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
