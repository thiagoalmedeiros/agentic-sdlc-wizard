{
  "name": "bitbucket-mcp",
  "command": "node",
  "module": "server.js",
  "env": [
    {
      "name": "BITBUCKET_URL",
      "description": "Bitbucket server URL",
      "required": true
    },
    {
      "name": "BITBUCKET_TOKEN",
      "description": "Bitbucket personal access token",
      "required": true
    },
    {
      "name": "BITBUCKET_USERNAME",
      "description": "Bitbucket username",
      "required": false
    }
  ]
}
