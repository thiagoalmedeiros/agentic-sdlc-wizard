{
  "name": "bitbucket-mcp",
  "enabled": false,
  "command": "node",
  "module": "server.js",
  "env": [
    {
      "name": "BITBUCKET_URL",
      "description": "Bitbucket API URL",
      "required": false,
      "default": "https://api.bitbucket.org/2.0"
    },
    {
      "name": "BITBUCKET_TOKEN",
      "description": "Bitbucket personal access token",
      "required": true
    },
    {
      "name": "BITBUCKET_EMAIL",
      "description": "Bitbucket email",
      "required": false
    }
  ]
}
